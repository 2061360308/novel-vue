{
  "bookSourceName": "Legado Shelf",
  "bookSourceType": 0,
  "bookSourceUrl": "https://你的域名",
  "bookSourceGroup": "自建",
  "header": "{\"Authorization\": \"Bearer 你的API_KEY\"}",
  "enabled": true,
  "comment": "部署教程: https://github.com/2061360308/legado-shelf\n导入后编辑书源，修改「书源URL」和「请求头」中的域名和API_KEY即可",

  "ruleSearch": {
    "bookList": "$.books[*]",
    "name": "t",
    "author": "a",
    "coverUrl": "https://你的域名/api/books/{{$.h}}/cover",
    "bookUrl": "h"
  },

  "ruleBookInfo": {
    "name": "t",
    "author": "a",
    "coverUrl": "https://你的域名/api/books/{{$.h}}/cover",
    "tocUrl": "https://你的域名/api/books/{{$.h}}/toc"
  },

  "ruleToc": {
    "chapterList": "$[*]",
    "chapterName": "t",
    "chapterUrl": "k"
  },

  "ruleContent": {
    "content": "$.content"
  },

  "searchUrl": "https://你的域名/api/books?q={{key}}",
  "contentUrl": "https://你的域名/api/books/{{baseUrl}}/chapters/{{chapterUrl}}"
}
