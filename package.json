{
  "name": "novel-vue",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n frontend,backend -c cyan,yellow \"vite\" \"wrangler dev --remote\"",
    "dev:backend": "wrangler dev --remote",
    "build": "vite build",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "typecheck": "vue-tsc --build"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "aws4fetch": "^1.0.20",
    "jszip": "^3.10.1",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.44.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.13.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^10.0.3",
    "npm-run-all2": "^9.0.2",
    "typescript": "~6.0.0",
    "vite": "^8.0.16",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vue-tsc": "^3.3.5",
    "wrangler": "^4.110.0"
  },
  "engines": {
    "node": "^22.18.0 || >=24.12.0"
  }
}
